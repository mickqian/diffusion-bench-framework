{
  "name": "20260601-h200-cosmos3",
  "purpose": "Targeted H200 Cosmos3 Nano comparison between SGLang-Diffusion PR #26926 and vLLM-Omni PR #3454.",
  "tracker_issue": "https://github.com/mickqian/diffusion-bench-framework/issues/1",
  "tracker_comment": "https://github.com/mickqian/diffusion-bench-framework/issues/1#issuecomment-4594218683",
  "reproduce_script": "scripts/run_h200_cosmos3_20260601.sh",
  "probe_scripts": [
    "scripts/probe_h200_cosmos3_sglang_profiles_20260601.sh",
    "scripts/probe_h200_cosmos3_vllm_omni_video_profiles_20260601.sh"
  ],
  "benchmark_repo": {
    "report_branch": "main",
    "result_harness_commit": "24f36206a6eb1cf8e1912ad78d77417b6cbc3782"
  },
  "sglang": {
    "repo_path": "/sgl-workspace/sglang",
    "expected_ref": "sgl-project/sglang#26926",
    "expected_commit": "b7718f8bf87cb676802c60fcf3c71664d243d9c7"
  },
  "frameworks": {
    "vllm": {
      "install_spec": "vllm==0.21.0"
    },
    "vllm_omni": {
      "install_spec": "git+https://github.com/MaciejBalaNV/vllm-omni.git@453bd09ab3d1e2f10e3d1b63ff05f090ab49a7cc",
      "expected_ref": "vllm-project/vllm-omni#3454",
      "expected_commit": "453bd09ab3d1e2f10e3d1b63ff05f090ab49a7cc",
      "server_bin": "vllm",
      "required_help_args": [
        "--omni",
        "--model-class-name",
        "--stage-init-timeout",
        "--no-guardrails",
        "--diffusion-attention-backend",
        "--cache-backend",
        "--cfg-parallel-size",
        "--ulysses-degree"
      ]
    }
  },
  "environment": {
    "hardware_profile": "h200",
    "cuda_visible_devices": "0,1,2,3",
    "framework_venv_root": "/root/.cache/sglang-diffusion-framework-venvs",
    "hf_cache": "/root/diffusion-bench-hf-cache/hub",
    "torch_compile_disable": "1",
    "vllm_extra_args": "--enforce-eager --compilation-config '{\"mode\":0}'",
    "non_ci_requirement": "Do not run this benchmark on CI, runner, build, GitHub Actions, Jenkins, or similar shared automation machines."
  },
  "formal_cases": [
    "cosmos3_nano_t2i_720p",
    "cosmos3_nano_t2v_720p_189f",
    "cosmos3_nano_i2v_720p_189f"
  ],
  "throughput_cases": [
    "cosmos3_nano_t2i_720p"
  ],
  "throughput_profile": {
    "num_requests": 8,
    "max_concurrency": 4,
    "request_rate": "inf"
  },
  "vllm_omni_video_probe_profiles": [
    "h200-4gpu-cfg-ulysses",
    "h200-4gpu-ulysses",
    "h200-4gpu-cfg",
    "h200-4gpu-auto",
    "h200-2gpu-cfg",
    "h200-2gpu-ulysses",
    "h200-2gpu-auto",
    "h200-1gpu-fa"
  ],
  "sglang_probe_profiles": {
    "image": [
      "h200-1gpu-fa",
      "h200-1gpu-fa-speed"
    ],
    "video": [
      "h200-4gpu-cfg-ulysses",
      "h200-4gpu-cfg-ulysses-speed",
      "h200-2gpu-cfg"
    ]
  },
  "case_profiles": {
    "cosmos3_nano_t2i_720p": {
      "sglang_profile": "h200-1gpu-fa",
      "vllm_omni_profile": "h200-1gpu-fa",
      "num_gpus": 1
    },
    "cosmos3_nano_t2v_720p_189f": {
      "sglang_profile": "h200-4gpu-cfg-ulysses",
      "vllm_omni_profile": "h200-4gpu-cfg-ulysses",
      "num_gpus": 4
    },
    "cosmos3_nano_i2v_720p_189f": {
      "sglang_profile": "h200-4gpu-cfg-ulysses",
      "vllm_omni_profile": "h200-4gpu-cfg-ulysses",
      "num_gpus": 4
    }
  },
  "best_effort_video_profiles": {
    "vllm_omni": {
      "profile": "h200-2gpu-cfg",
      "reason": "vLLM-Omni 4-GPU Ulysses and CFG+Ulysses profiles fail before health check; the fastest successful video profile observed is 2-GPU CFG-only."
    }
  },
  "result_files": {
    "single_formal": "runs/h200-cosmos3-20260601-fb91e53-b7718f8-vllm021-ion7-single.json",
    "sglang_speed_probe": "runs/h200-cosmos3-sglang-profile-probe-ade55a7-b7718f8-*.json",
    "vllm_omni_video_probe": "runs/h200-cosmos3-vllm-omni-video-probe-efc4998-vllm021-cosmos3_nano_t2v_720p_189f-h200-*.json",
    "vllm_omni_i2v_best_effort": "runs/h200-cosmos3-vllm-omni-i2v-best-effort-efc4998-vllm021-cosmos3_nano_i2v_720p_189f-h200-2gpu-cfg.json",
    "t2i_throughput_c4": "runs/h200-cosmos3-t2i-throughput-c4-efc4998-b7718f8-vllm021.json"
  },
  "notes": [
    "Guardrails are disabled for both frameworks to measure framework/model serving performance without safety-model overhead.",
    "No response cache, Cache-DiT, quantized checkpoint, reduced-step model, or torch compile path is enabled.",
    "Video cases use the same 4-GPU budget and the same 1280x720, 189-frame, 35-step, CFG 6.0 request parameters.",
    "The formal vLLM-Omni video profile is 4-GPU CFG+Ulysses for fairness; best-effort successful video rows are reported separately because they use fewer effective GPUs."
  ]
}
